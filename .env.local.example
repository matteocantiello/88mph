# Spotify API Credentials
# Get yours at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Save to Spotify (playlist creation — requires Spotify dev mode, 5 user limit)
# Set to "true" to show the Save to Spotify button
NEXT_PUBLIC_ENABLE_SPOTIFY_SAVE=false
# Generate a secure random value with: openssl rand -hex 32
SPOTIFY_COOKIE_SECRET=your_64_char_hex_string_here
# Your app's public URL (no trailing slash)
# For local dev use http://127.0.0.1:3000 (Spotify does NOT allow "localhost")
# For production use your https:// URL
NEXT_PUBLIC_BASE_URL=http://127.0.0.1:3000
